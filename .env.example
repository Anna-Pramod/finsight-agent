# ============================================================================
# FinSight Agent — example environment configuration
# Copy to `.env` and fill in. NEVER commit a real .env (see .gitignore).
# Values below are placeholders / safe defaults for local development.
# ============================================================================

# ---- Gemini / Vertex AI ----------------------------------------------------
# Option A: Gemini API key (simplest for local dev; matches fi-mcp-dev example)
GOOGLE_API_KEY=your-gemini-api-key

# Option B: Vertex AI (used for Cloud Run / production). When using Vertex,
# set GOOGLE_GENAI_USE_VERTEXAI=TRUE and provide project + location.
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model used by the ADK agents (upstream example uses gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ---- Fi MCP Dev (the MCP foundation) ---------------------------------------
# Local fi-mcp-dev server. Confirmed endpoint path: /mcp/stream
FI_MCP_BASE_URL=http://localhost:8080
FI_MCP_STREAM_PATH=/mcp/stream
# Custom session IDs MUST start with this prefix (confirmed upstream requirement)
MCP_SESSION_PREFIX=mcp-session-
# Demo persona phone number (one of the test_data_dir personas), e.g. 2222222222
FI_MCP_DEMO_PHONE=2222222222

# ---- Backend (FastAPI on Cloud Run) ----------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO
# Comma-separated origins allowed to call the backend (the frontend origin)
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js -> GitHub Pages) ------------------------------------
# Public base URL of the deployed backend API (Cloud Run URL in production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
